# Vite exposes only vars prefixed with VITE_
# Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use the “anon” / “public” JWT key, or the publishable key shown in newer dashboards
VITE_SUPABASE_ANON_KEY=your_key_here

# Optional: if you only have a publishable key variable name from docs, use this instead:
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
